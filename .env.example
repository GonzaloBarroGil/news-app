# Guardian Open Platform API key (required)
GUARDIAN_API_KEY=your-guardian-api-key-here

# Guardian API base URL (default: https://content.guardianapis.com)
GUARDIAN_BASE_URL=https://content.guardianapis.com

# Guardian API request timeout in milliseconds (default: 10000)
GUARDIAN_TIMEOUT_MS=10000

# Redis/Valkey connection URL (required — Upstash or local)
REDIS_URL=redis://localhost:6379

# Cache TTL for article lists in seconds (default: 300)
CACHE_TTL_ARTICLES=300

# Node environment (development | production)
NODE_ENV=development

# BFF server port (default: 3001)
PORT=3001

# Frontend origin for CORS (default: http://localhost:3000)
FRONTEND_ORIGIN=http://localhost:3000

# BFF URL for frontend API client (default: http://localhost:3001/api/v1)
NEXT_PUBLIC_BFF_URL=http://localhost:3001/api/v1
